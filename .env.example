# WhatsApp Cloud API credentials — from https://developers.facebook.com/
# (your app → WhatsApp → API Setup)
ACCESS_TOKEN=your_meta_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here

# Choose any string — must match the verify token you enter in Meta's webhook config
VERIFY_TOKEN=my-secret-verify-token

# Optional — for cloud deploys where Ollama isn't available (free key: https://console.groq.com)
# Locally the bot prefers Ollama/Mistral; it falls back to Groq only if Ollama is unreachable
GROQ_API_KEY=

